<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- Top Bar -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_detail_top_bar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        app:layout_constraintTop_toTopOf="parent">

        <FrameLayout
            android:id="@+id/iv_detail_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="@drawable/bg_ripple_circle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">
            
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_back_arrow" />
        </FrameLayout>

        <TextView
            android:id="@+id/tv_detail_top_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Nike Everyday Plus Cush..."
            android:textSize="16sp"
            android:textColor="@color/black"
            android:gravity="center"
            android:maxLines="1"
            android:ellipsize="end"
            android:textStyle="bold"
            android:layout_marginHorizontal="16dp"
            app:layout_constraintStart_toEndOf="@id/iv_detail_back"
            app:layout_constraintEnd_toStartOf="@id/iv_detail_search"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <FrameLayout
            android:id="@+id/iv_detail_search"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="@drawable/bg_ripple_circle"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">
            
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_nav_shop" />
        </FrameLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/cl_detail_top_bar"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <ImageView
                android:id="@+id/iv_detail_main_img"
                android:layout_width="match_parent"
                android:layout_height="250dp"
                android:src="@drawable/img_shoe_1"
                android:scaleType="fitCenter" />

            <!-- Sub Images (Dummy) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="8dp">

                <ImageView
                    android:id="@+id/iv_detail_sub_1"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/img_shoe_1"
                    android:layout_marginHorizontal="4dp" />
                <ImageView
                    android:id="@+id/iv_detail_sub_2"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/img_shoe_1"
                    android:layout_marginHorizontal="4dp" />
                <ImageView
                    android:id="@+id/iv_detail_sub_3"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/img_shoe_1"
                    android:layout_marginHorizontal="4dp" />
                <ImageView
                    android:id="@+id/iv_detail_sub_4"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/img_shoe_1"
                    android:layout_marginHorizontal="4dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_detail_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Training Crew Socks"
                android:textColor="#757575"
                android:textSize="14sp"
                android:layout_marginTop="16dp"
                android:layout_marginHorizontal="24dp" />

            <TextView
                android:id="@+id/tv_detail_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nike Everyday Plus Cushioned"
                android:textColor="@color/black"
                android:textSize="24sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp"
                android:layout_marginHorizontal="24dp" />

            <TextView
                android:id="@+id/tv_detail_price"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="US$10"
                android:textColor="@color/black"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginTop="16dp"
                android:layout_marginHorizontal="24dp" />

            <!-- Dummy description since exact text is not critical per user -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="The Nike Everyday Plus Cushioned Socks bring comfort to your workout with extra cushioning under the heel and forefoot and a snug, supportive arch band. Sweat-wicking power and breathability up top help keep your feet dry and cool to help push you through that extra set."
                android:textColor="#333333"
                android:textSize="14sp"
                android:lineSpacingExtra="4dp"
                android:layout_marginTop="24dp"
                android:layout_marginHorizontal="24dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="16dp"
                android:layout_marginHorizontal="32dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="• Shown: Multi-Color"
                    android:textColor="#333333"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="• Style: SX6897-965"
                    android:textColor="#333333"
                    android:textSize="14sp"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="View Product Details"
                android:textColor="#757575"
                android:textSize="14sp"
                android:layout_marginTop="16dp"
                android:layout_marginHorizontal="24dp" />

            <!-- Buttons -->
            <Button
                android:id="@+id/btn_detail_size"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="사이즈 선택"
                android:textColor="@color/white"
                android:background="@drawable/shape_btn_pill_black"
                android:layout_marginTop="32dp"
                android:layout_marginHorizontal="24dp"
                android:textSize="16sp" />

            <Button
                android:id="@+id/btn_detail_cart"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="장바구니에 추가"
                android:textColor="@color/white"
                android:background="@drawable/shape_btn_pill_black"
                android:textStyle="bold"
                android:layout_marginTop="12dp"
                android:layout_marginHorizontal="24dp"
                android:textSize="16sp" />

            <Button
                android:id="@+id/btn_detail_wishlist"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="위시리스트"
                android:textColor="@color/white"
                android:background="@drawable/shape_btn_pill_black"
                android:layout_marginTop="12dp"
                android:layout_marginHorizontal="24dp"
                android:textSize="16sp" />

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
