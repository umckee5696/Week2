<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?android:attr/selectableItemBackground">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingVertical="12dp"
        android:paddingHorizontal="16dp">

    <!-- 썸네일 이미지 (작게) -->
    <ImageView
        android:id="@+id/iv_cart_item_img"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:scaleType="centerCrop"
        android:contentDescription="@string/tab_cart"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- 상품명 -->
    <TextView
        android:id="@+id/tv_cart_item_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Product Title"
        android:textColor="@color/black"
        android:textSize="14sp"
        android:textStyle="bold"
        android:maxLines="1"
        android:ellipsize="end"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="8dp"
        app:layout_constraintStart_toEndOf="@id/iv_cart_item_img"
        app:layout_constraintEnd_toStartOf="@id/iv_cart_item_delete"
        app:layout_constraintTop_toTopOf="@id/iv_cart_item_img"
        app:layout_constraintBottom_toTopOf="@id/tv_cart_item_subtitle" />

    <!-- 설명 (카테고리) -->
    <TextView
        android:id="@+id/tv_cart_item_subtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Subtitle"
        android:textColor="#757575"
        android:textSize="12sp"
        android:maxLines="1"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="8dp"
        app:layout_constraintStart_toEndOf="@id/iv_cart_item_img"
        app:layout_constraintEnd_toStartOf="@id/iv_cart_item_delete"
        app:layout_constraintTop_toBottomOf="@id/tv_cart_item_title" />

    <!-- 가격 -->
    <TextView
        android:id="@+id/tv_cart_item_price"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="US$0"
        android:textColor="@color/black"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="8dp"
        android:layout_marginTop="4dp"
        app:layout_constraintStart_toEndOf="@id/iv_cart_item_img"
        app:layout_constraintEnd_toStartOf="@id/iv_cart_item_delete"
        app:layout_constraintTop_toBottomOf="@id/tv_cart_item_subtitle" />

    <!-- X 삭제 버튼 -->
    <FrameLayout
        android:id="@+id/iv_cart_item_delete"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:clickable="true"
        android:focusable="true"
        android:foreground="@drawable/bg_ripple_circle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">
        
        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:contentDescription="삭제" />
    </FrameLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</FrameLayout>
